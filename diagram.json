{
  "version": 1,
  "author": "Jose Dhonatan",
  "editor": "wokwi",

  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },

    {
      "type": "wokwi-ssd1306",
      "id": "oled",
      "top": -180,
      "left": -180,
      "attrs": {
        "i2cAddress": "0x3c"
      }
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btnFeed",
      "top": -100,
      "left": 220,
      "attrs": {}
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btnPlay",
      "top": -20,
      "left": 220,
      "attrs": {}
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btnSleep",
      "top": 60,
      "left": 220,
      "attrs": {}
    }
  ],

  "connections": [

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "esp:21", "oled:DATA", "green", [] ],
    [ "esp:22", "oled:CLK", "yellow", [] ],
    [ "esp:3V3", "oled:3V3", "red", [] ],
    [ "esp:GND.1", "oled:GND", "black", [] ]

    [ "esp:14", "btnFeed:1.l", "green", [] ],
    [ "btnFeed:2.r", "esp:GND.1", "black", [] ],

    [ "esp:27", "btnPlay:1.l", "blue", [] ],
    [ "btnPlay:2.r", "esp:GND.1", "black", [] ],

    [ "esp:26", "btnSleep:1.l", "yellow", [] ],
    [ "btnSleep:2.r", "esp:GND.1", "black", [] ]
  ]
}
